# Salin file ini ke .env.local dan isi nilainya

# URL dashboard yang digunakan SERVER-SIDE proxy (tidak pernah dikirim ke browser).
# Boleh berupa IP + port karena diakses dari server Vercel, bukan dari browser.
# Contoh pakai IP VPS : http://123.45.67.89:3001
# Contoh pakai domain  : https://dashboard.yourdomain.com
DASHBOARD_INTERNAL_URL=http://your-vps-ip:3001

# API key rahasia yang sama dengan LANDING_API_KEY di sequndang-dashboard.
# Gunakan prefix tanpa NEXT_PUBLIC_ agar TIDAK bocor ke browser bundle.
LANDING_API_KEY_SECRET=your-api-key-here
