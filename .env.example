# Salin file ini ke .env.local dan isi nilainya

# URL publik dari sequndang-dashboard yang sudah di-deploy
# Contoh: https://dashboard.sequndang.com
NEXT_PUBLIC_DASHBOARD_URL=https://your-dashboard-url.vercel.app

# API key yang sama dengan LANDING_API_KEY di sequndang-dashboard
NEXT_PUBLIC_LANDING_API_KEY=your-api-key-here
